{
  "name": "synapse-backend",
  "version": "1.0.0",
  "description": "Synapse — misconception-driven quiz learning system backend",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/api/server.ts",
    "build": "tsc",
    "start": "node dist/api/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src scripts test",
    "format": "prettier --write .",
    "seed-tracks": "tsx scripts/seed-tracks.ts",
    "bootstrap": "tsx scripts/bootstrap.ts",
    "nightly": "tsx scripts/run-nightly.ts"
  },
  "dependencies": {
    "@google/genai": "^1.0.0",
    "@mozilla/readability": "^0.5.0",
    "compression": "^1.8.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "jsdom": "^25.0.1",
    "mongodb-memory-server": "^10.4.3",
    "mongoose": "^8.10.1",
    "pdf-parse": "^1.1.1",
    "supertest": "^7.2.2",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "ts-fsrs": "^4.3.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.10.7",
    "@types/pdf-parse": "^1.1.4",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4"
  }
}
