MONGODB_URI=mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/synapse?retryWrites=true&w=majority
APP_TOKEN=<generate-with: openssl rand -hex 32>
GEMINI_API_KEY=<your-gemini-api-key>
TELEGRAM_BOT_TOKEN=<your-telegram-bot-token>
TELEGRAM_CHAT_ID=<numeric-chat-id-from-getUpdates>
PORT=3000
NODE_ENV=development
